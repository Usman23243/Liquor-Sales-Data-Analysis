   "source": [
    "print(\"Sawaal 5: Saal ka sab se acha maheena konsa tha?\\n\")\n",
    "\n",
    "# Hum date ke pehle 7 characters (YYYY-MM) nikal rahe hain taake maheena ban jaye\n",
    "query5 = \"\"\"\n",
    "SELECT substr(SalesDate, 1, 7) as Month, SUM(SalesDollars) as Monthly_Revenue \n",
    "FROM sales \n",
    "GROUP BY Month \n",
    "ORDER BY Month ASC\n",
    "\"\"\"\n",
    "\n",
    "# Data load karna\n",
    "monthly_sales = pd.read_sql(query5, con=engine)\n",
    "\n",
    "# Revenue ko format karna\n",
    "monthly_sales['Monthly_Revenue'] = monthly_sales['Monthly_Revenue'].map('${:,.2f}'.format)\n",
    "\n",
    "print(\"📅 Har Maheene ki Kamai (Trend):\")\n",
    "display(monthly_sales)"
   ]
  },
