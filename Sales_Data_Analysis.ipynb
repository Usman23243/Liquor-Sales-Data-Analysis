   "source": [
    "print(\"Sawaal 4: Konsa Store sab se zyada paisa kama raha hai?\\n\")\n",
    "\n",
    "# Hum 'Store' ke column ko group kar ke uski saari sales ko plus (SUM) kar rahe hain\n",
    "query4 = \"\"\"\n",
    "SELECT Store, SUM(SalesDollars) as Store_Revenue \n",
    "FROM sales \n",
    "GROUP BY Store \n",
    "ORDER BY Store_Revenue DESC \n",
    "LIMIT 5\n",
    "\"\"\"\n",
    "\n",
    "# Database se data lana\n",
    "top_stores = pd.read_sql(query4, con=engine)\n",
    "\n",
    "# Amount ko pyara dikhane ke liye format lagana\n",
    "top_stores['Store_Revenue'] = top_stores['Store_Revenue'].map('${:,.2f}'.format)\n",
    "\n",
    "print(\"🏢 Top 5 Stores (Sab se achi branches):\")\n",
    "display(top_stores)"
   ]
  },
