    "import pandas as pd\n",
    "from sqlalchemy import create_engine\n",
    "\n",
    "engine = create_engine('sqlite:///inventory.db')\n",
    "\n",
    "# Sirf sales file ka rasta\n",
    "sales_file_path = r\"C:\\Users\\Lenovo\\Downloads\\data\\sales.csv\"\n",
    "\n",
    "print(\"Sales data chote hisson (chunks) mein load ho raha hai...\")\n",
    "print(\"Isme 5 se 10 minute lag sakte hain, please wait...\\n\")\n",
    "\n",
    "# Ek waqt mein sirf 1 lakh lines read hongi aur save hongi\n",
    "chunk_size = 100000 \n",
    "chunk_number = 1\n",
    "first_chunk = True\n",
    "\n",
    "# Data ko tukron (chunks) mein read karna\n",
    "for chunk in pd.read_csv(sales_file_path, chunksize=chunk_size):\n",
    "    if first_chunk:\n",
    "        # Pehle chunk ke waqt naya table banega (replace)\n",
    "        chunk.to_sql('sales', con=engine, index=False, if_exists='replace')\n",
    "        first_chunk = False\n",
    "    else:\n",
    "        # Baqi chunks purane table ke neechay add hote jayenge (append)\n",
    "        chunk.to_sql('sales', con=engine, index=False, if_exists='append')\n",
    "        \n",
    "    print(f\"Chunk {chunk_number} save ho gaya (1 Lakh lines)...\")\n",
    "    chunk_number += 1\n",
    "\n",
    "print(\"\\n🎉 Zabardast! Sales ka 1.5 GB data bhi successfully database mein save ho gaya!\")"
   ]
  },
