    "import matplotlib.pyplot as plt\n",
    "\n",
    "print(\"Graph banaya ja raha hai... please wait!\\n\")\n",
    "\n",
    "# Step 1: Data ko graph ke qabil banana (Kyunke humne pichle code mein $ aur comma laga diya tha, usay wapis number banana zaroori hai)\n",
    "monthly_sales['Raw_Revenue'] = monthly_sales['Monthly_Revenue'].replace('[\\$,]', '', regex=True).astype(float)\n",
    "\n",
    "# Step 2: Graph ka size aur design set karna\n",
    "plt.figure(figsize=(12, 6)) # (Lumbai, Chorai)\n",
    "plt.plot(monthly_sales['Month'], monthly_sales['Raw_Revenue'], marker='o', color='green', linewidth=2, markersize=8)\n",
    "\n",
    "# Step 3: Graph ko labels aur title dena\n",
    "plt.title('2024 Har Maheene Ki Kamai (Monthly Sales Trend)', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Maheena (Month)', fontsize=12)\n",
    "plt.ylabel('Kamai (Dollars Mein)', fontsize=12)\n",
    "plt.xticks(rotation=45) # Maheeno ke naam thode terhay (tilted) dikhane ke liye taake mix na hon\n",
    "plt.grid(True, linestyle='--', alpha=0.6) # Peeche lines lagane ke liye\n",
    "\n",
    "# Step 4: Graph dikhana\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
