    "import pandas as pd\n",
    "from sqlalchemy import create_engine\n",
    "\n",
    "# 1. Aapka apna Database connection wala code\n",
    "engine = create_engine('sqlite:///inventory.db')\n",
    "\n",
    "# 2. Asli file ka mukammal rasta (Path)\n",
    "# r lagana zaroori hai, aur humne Downloads/data wala path likha hai\n",
    "file_path = r\"C:\\Users\\Lenovo\\Downloads\\data\\begin_inventory.csv\"\n",
    "\n",
    "# 3. CSV file ko Pandas DataFrame mein read karein\n",
    "print(\"Data load ho raha hai, please wait...\")\n",
    "df_begin_inv = pd.read_csv(file_path)\n",
    "\n",
    "# 4. Data ko Database (SQL) mein save karein!\n",
    "# 'begin_inventory' aapke table ka naam hoga database ke andar\n",
